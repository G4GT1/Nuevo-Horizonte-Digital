# ============================================================
# SERVIDOR
# ============================================================
PORT=4000
NODE_ENV=development

# ============================================================
# BASE DE DATOS
# ============================================================
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=horizonte_verde

# ============================================================
# JWT
# ============================================================
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga_2026
REFRESH_SECRET_KEY=cambia_esto_por_otra_clave_secreta_refresh_2026

# ============================================================
# CORS — dominio del frontend
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# RESEND (emails)
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@horizonteverde.com

# ============================================================
# FIELDCLIMATE API v2 (sensores GSM — Pessl/METOS)
# ============================================================
FIELDCLIMATE_PUBLIC_KEY=tu_public_key_fieldclimate
FIELDCLIMATE_PRIVATE_KEY=tu_private_key_fieldclimate
FIELDCLIMATE_BASE_URL=https://api.fieldclimate.com/v2

# ============================================================
# CESENS API (sensores LoRa)
# ============================================================
CESENS_BASE_URL=https://app.cesens.com/api
CESENS_NOMBRE=tu_nombre_usuario_cesens
CESENS_CLAVE=tu_clave_cesens

# ============================================================
# OPEN-METEO (predicción meteorológica — sin API key)
# ============================================================
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
STATION_LATITUDE=37.88
STATION_LONGITUDE=-4.75

# ============================================================
# GROQ API (IA — chatbot + buscador)
# ============================================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================
# WEB PUSH (notificaciones push al navegador)
# ============================================================
VAPID_PUBLIC_KEY=genera_con_npx_web-push_generate-vapid-keys
VAPID_PRIVATE_KEY=genera_con_npx_web-push_generate-vapid-keys
VAPID_SUBJECT=mailto:admin@horizonteverde.com

# ============================================================
# SEED — primer SuperAdmin (solo para npm run seed)
# ============================================================
SEED_ADMIN_EMAIL=admin@horizonteverdedigital.es
SEED_ADMIN_PASSWORD=CambiaMePorUnaContraseñaSegura123!
SEED_ADMIN_NOMBRE=Administrador
